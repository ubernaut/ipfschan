{
  "name": "ipfschan",
  "version": "1.0.0",
  "description": "IPFS-hosted imageboard rebuilt from scratch. The goal is to let each user host their own posts and media on IPFS, while the app aggregates threads, tags, and replies.",
  "type": "module",
  "main": "src/server/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node src/server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node src/server/index.js",
    "test": "vitest run",
    "smoke": "node scripts/smoke.js",
    "verify": "npm test && npm run build && npm run smoke",
    "reset": "node scripts/reset-data.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@helia/block-brokers": "^5.2.4",
    "@helia/dag-json": "^5.1.1",
    "@helia/unixfs": "^7.2.1",
    "@libp2p/noise": "^1.0.1",
    "@libp2p/tcp": "^11.0.22",
    "@libp2p/websockets": "^10.1.15",
    "blockstore-fs": "^4.0.1",
    "blockstore-idb": "^3.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helia": "^6.1.4",
    "libp2p": "^3.3.4",
    "multer": "^2.2.0",
    "multiformats": "^13.4.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
